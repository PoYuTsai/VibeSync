# ios/fastlane/Fastfile
# Fastlane configuration for iOS deployment
# Note: IPA is built by flutter build ipa in GitHub Actions, not by Fastlane

default_platform(:ios)

platform :ios do
  desc "Upload existing IPA to TestFlight"
  lane :beta do
    # Find the IPA built by flutter build ipa
    # Use absolute path to avoid working directory issues
    # Fastfile is at ios/fastlane/Fastfile, so go up 3 levels to reach project root
    project_root = File.expand_path("../../..", __FILE__)
    ipa_dir = File.join(project_root, "build", "ios", "ipa")

    # Try to find any .ipa file in the directory
    ipa_files = Dir.glob(File.join(ipa_dir, "*.ipa"))

    if ipa_files.empty?
      UI.user_error!("No IPA found in #{ipa_dir}. Make sure 'flutter build ipa' completed successfully.")
    end

    ipa_path = ipa_files.first
    UI.message("Found IPA at: #{ipa_path}")

    # Upload to TestFlight
    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      api_key: app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY"]
      )
    )

    # Notify via Slack if webhook URL is set and valid
    slack_url = ENV["SLACK_WEBHOOK_URL"]
    if slack_url && slack_url.start_with?("https://")
      slack(
        message: "VibeSync iOS build uploaded to TestFlight! 🚀",
        slack_url: slack_url,
        default_payloads: [:git_branch, :last_git_commit_message]
      )
    else
      UI.message("Slack notification skipped (no valid webhook URL)")
    end
  end

  desc "Build for local testing"
  lane :build do
    build_app(
      scheme: "Runner",
      workspace: "Runner.xcworkspace",
      export_method: "development",
      output_directory: "./build"
    )
  end
end
