# VibeSync Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Claude API (for Edge Functions - set in Supabase Dashboard)
# CLAUDE_API_KEY=sk-ant-xxxxx

# RevenueCat (Flutter build-time keys)
REVENUECAT_SANDBOX_KEY=appl_xxxxxxxx
REVENUECAT_PROD_KEY=appl_xxxxxxxx
# RevenueCat Webhook (Edge Function)
# Set in Supabase Dashboard -> Edge Functions env
# REVENUECAT_WEBHOOK_SECRET=your-webhook-secret-here

# Internal test-account bypass (Edge Function env only, comma-separated)
# TEST_ACCOUNT_EMAILS=internal-test@example.com

# Security alerting (Edge Function env only)
# SECURITY_ALERT_SECRET=your-strong-shared-secret
# TELEGRAM_BOT_TOKEN=xxxx
# TELEGRAM_SECURITY_CHAT_ID=xxxx
# SECURITY_ALERT_WEBHOOK_URL=https://hooks.example.com/security
# SECURITY_ALERT_WEBHOOK_BEARER_TOKEN=optional-bearer-token
