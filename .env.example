# VibeSync Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Claude API (for Edge Functions - set in Supabase Dashboard)
# CLAUDE_API_KEY=sk-ant-xxxxx

# RevenueCat public SDK key for app builds
REVENUECAT_API_KEY=appl_xxxxxxxx

# RevenueCat server key for Edge Functions
REVENUECAT_IOS_API_KEY=your-revenuecat-ios-secret-key
# RevenueCat Webhook (Edge Function)
# Set in Supabase Dashboard -> Edge Functions env
# REVENUECAT_WEBHOOK_SECRET=your-webhook-secret-here

# Feedback notification (Edge Function)
# Set in Supabase Dashboard -> Edge Functions env
# DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Or use bot delivery if the Discord bot lacks webhook permissions
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_FEEDBACK_CHANNEL_ID=1487899618090946634
