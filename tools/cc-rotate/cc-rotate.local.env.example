# cc-rotate per-machine config — copy to ~/.claude/channels/discord-vibesync/cc-rotate.local.env then chmod 600
# This file IS tracked (it's the template). The real .local.env is gitignored.
#
# All paths MUST be absolute. No ~ expansion (some bash shells in nested invocations skip it).

# === Required ===

# Absolute path to VibeSync repo on this machine.
VIBESYNC_REPO=/absolute/path/to/VibeSync

# Channel runtime dir — where signal files (request.json / bootstrap.json / lock) live.
# This is the same dir as start.sh / access.json / .env / bridge.pid.
CC_ROTATE_DIR=/home/<linux-user>/.claude/channels/discord-vibesync

# Command that supervisor spawns to start a new claude session.
# Must include the Discord plugin channels flag so the new session reconnects DC.
CLAUDE_CMD="claude --dangerously-skip-permissions --channels plugin:discord@claude-plugins-official"

# Absolute path to Claude Code memory dir for this project.
# Find yours with: ls ~/.claude/projects/ | grep VibeSync
HANDOFF_DIR=/home/<linux-user>/.claude/projects/<project-slug>/memory

# === Optional (defaults shown) ===

# Filename of the "latest" handoff file (overwritten on every rotate).
# Dated milestone copies are out of scope for v1.
HANDOFF_LATEST_FILENAME=reference_session_handoff_latest.md

# Bootstrap.json TTL — older than this seconds gets discarded as stale (R3 mitigation).
# Keep this long enough for mobile users to notice "no ready" and send a follow-up prompt.
BOOTSTRAP_TTL_SECONDS=1800

# Supervisor SIGTERM grace period before falling back to SIGKILL (R5 mitigation).
SIGTERM_TIMEOUT_SECONDS=30

# Lock file age for B4 auto-recovery — if lock exists but is older than this,
# supervisor treats it as stale and clears it (handles crash during previous rotate).
LOCK_STALE_SECONDS=120
