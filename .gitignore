# Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment
.env
.env.*
!.env.example

# cc-rotate per-machine config (real values not tracked; .example is)
*.local.env
!*.local.env.example

# Supabase
supabase/.branches
supabase/.temp

# Generated
*.g.dart
*.freezed.dart

# Test
coverage/

# Secrets (never commit)
**/secrets/
*.keystore
*.jks
# Note: google-services.json and GoogleService-Info.plist are safe to commit
# They only contain public API keys; security is enforced by Firebase Rules

# API Keys & Credentials
*.key
*.pem
*.p12
**/credentials/
service-account*.json

# Supabase local config (contains keys)
supabase/.env
supabase/.env.local
.worktrees/

# Local Claude Code / MCP config (per-machine, not project state)
.claude/*
!.claude/settings.local.json
!.claude/commands/
!.claude/commands/round.md
.claude/skills.disabled/
.mcp.json

# Externally-cloned GitHub Pages repo (has its own .git, should live outside this repo)
vibesync-web/

# OCR golden set：真實圖 labels 與跑分結果不入 git（隱私）
tools/ocr-golden/labels/real/
tools/ocr-golden/results/
tools/ocr-golden/.env.golden

# voice-benchmark 黑箱驗證跑分輸出（throwaway，留本機供檢視，不入 git）
tools/voice-benchmark/baselines/verify_*.ndjson
